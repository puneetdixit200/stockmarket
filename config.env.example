# Runtime mode: FULL, TEST, or RESUME.
MODE=TEST

# Hosted REST API documented in https://github.com/0xramm/Indian-Stock-Market-API
INDIAN_STOCK_API_BASE_URL=http://65.0.104.9/

# Limit Screener requests to reduce blocking risk.
SCREENER_MAX_PER_RUN=25
SCREENER_SLEEP_SECONDS=2.5

# Full runs default to the live Nifty LargeMidcap 250 universe.
DEFAULT_OUTPUT_DIR=outputs
DATABASE_PATH=database/stocks.db
